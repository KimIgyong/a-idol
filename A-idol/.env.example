# ============================================================
# A-idol local development environment variables
# Copy this file to `.env` and adjust values as needed.
# ============================================================

# ---------- Backend (NestJS) ----------
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# PostgreSQL connection (docker-compose default)
DATABASE_URL=postgresql://aidol:aidol_dev@localhost:5433/aidol?schema=public

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-0123456789abcdef
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-0123456789abcdef
JWT_REFRESH_EXPIRES_IN=14d

# Password hashing cost
BCRYPT_ROUNDS=10

# OAuth (optional for Phase 2 — not required for email sign-up to work)
KAKAO_CLIENT_ID=
APPLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:8081
