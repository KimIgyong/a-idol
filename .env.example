# ============================================================
# A-idol local development environment variables
# Copy this file to `.env` and adjust values as needed.
# ============================================================

# ---------- Backend (NestJS) ----------
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# PostgreSQL connection (docker-compose default)
DATABASE_URL=postgresql://aidol:aidol_dev@localhost:5433/aidol?schema=public

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-0123456789abcdef
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-0123456789abcdef
JWT_REFRESH_EXPIRES_IN=14d

# Password hashing cost
BCRYPT_ROUNDS=10

# OAuth (optional for Phase 2 — not required for email sign-up to work)
KAKAO_CLIENT_ID=
APPLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:8081

# Global rate-limit (req/min/IP). /health 와 /metrics 는 SkipThrottle.
# k6 staging 부하 측정 시 100000+로 상향. dev/prod default 200.
THROTTLE_LIMIT_PER_MINUTE=200

# HIBP (Have I Been Pwned) breach DB 조회 — k-anonymity API.
# dev/test=0(off), staging/prod=1. 네트워크 실패는 graceful pass (DoS 방지).
HIBP_CHECK_ENABLED=0
# HIBP_API_BASE=https://api.pwnedpasswords.com  # 자체 mirror 시 override

# Sentry (T-080 외부 5xx capture). DSN 비어있으면 SDK init skip (graceful no-op).
# staging/prod 에서 발급된 DSN 입력. tracesSampleRate 0~1 (0.1=10% 샘플링).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# CMS (Vite) — VITE_ prefix 로 inline. 빈 값이면 SDK init skip.
VITE_SENTRY_DSN=
VITE_APP_ENV=development

# Mobile (Expo) — EXPO_PUBLIC_ prefix 로 inline. 빈 값이면 SDK init skip.
# EAS build 시 secrets로 주입 권장.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_APP_ENV=development
