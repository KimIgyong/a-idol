# A-idol staging — 환경 변수 템플릿
# 실제 운영용 .env.staging 은 본 파일을 복사 후 값을 채워 사용. .gitignore 됨.
#
# 사용:
#   cp deploy/staging/.env.staging.example deploy/staging/.env.staging
#   vim deploy/staging/.env.staging   # secrets 채우기
#   docker compose -f deploy/staging/docker-compose.staging.yml --env-file deploy/staging/.env.staging up -d --build

# ---------- Postgres (compose 내부 통신) ----------
POSTGRES_USER=aidol
POSTGRES_PASSWORD=__GENERATE_STRONG_PASSWORD__
POSTGRES_DB=aidol

# ---------- Backend ----------
LOG_LEVEL=info

# JWT — `openssl rand -base64 64` 로 생성. dev 시드와 절대 동일하게 두지 말 것.
JWT_ACCESS_SECRET=__GENERATE_64_BYTE_RANDOM__
JWT_REFRESH_SECRET=__GENERATE_64_BYTE_RANDOM_DIFFERENT__
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=14d

# bcrypt — staging 에서 12 (prod 동일). dev 는 10.
BCRYPT_ROUNDS=12

# CORS — staging 에서 CMS 도메인만 허용. mobile 은 file:// 또는 native 라 origin 없음.
CORS_ORIGINS=https://a-idol-stg.amoeba.site

# Throttle — k6 본 측정 시 100000 으로 일시 상향, 측정 후 200 복귀.
THROTTLE_LIMIT_PER_MINUTE=200

# HIBP — staging 부터 enable (HaveIBeenPwned breach DB 조회).
HIBP_CHECK_ENABLED=1

# Sentry — Developer plan DSN. 비워두면 graceful no-op.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# OAuth (옵션) — sandbox client id. 발급 후 채움.
KAKAO_CLIENT_ID=
APPLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
